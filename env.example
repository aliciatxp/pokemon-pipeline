# ── Pokemon Card Pipeline Configuration ──────────────────────────
# Copy this file to .env and fill in your values.
# Never commit .env to git.

# Your Google AI Studio API key (for Gemini card name translation)
# Get one free at: https://aistudio.google.com/ → Get API key → Create API key
# Select your pokemon-pipeline Google Cloud project when prompted
GOOGLE_AI_API_KEY=AIzaSy-your-key-here

# Google Sheets spreadsheet ID
# This is the long string in your sheet's URL:
# https://docs.google.com/spreadsheets/d/THIS_PART_HERE/edit
GOOGLE_SHEET_ID=your_spreadsheet_id_here

# Name of the tab/sheet inside your spreadsheet
GOOGLE_SHEET_TAB=Inventory

# Path to your Google service account credentials JSON file
GOOGLE_CREDENTIALS_FILE=credentials.json
